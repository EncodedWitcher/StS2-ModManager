<Window x:Class="StS2ModManager.SaveProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保存为配置组合"
        Width="440"
        Height="470"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#FFF8F0E5"
        FontFamily="Bahnschrift">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="保存为配置组合"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#FF201913" />

        <TextBlock Grid.Row="1"
                   Text="选择一个已有组合进行覆盖，或点击“新组合”创建一个新的。"
                   Margin="0,10,0,12"
                   Foreground="#FF6F6258"
                   TextWrapping="Wrap" />

        <Border Grid.Row="2"
                BorderBrush="#FFDDD0BE"
                BorderThickness="1"
                CornerRadius="10"
                Background="#FFFFFFFF">
            <Grid>
                <TextBlock x:Name="EmptyHint"
                           Text="还没有任何配置组合，点击“新组合”创建。"
                           Margin="14"
                           Foreground="#FF9A8C7C"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
                <ListBox x:Name="ProfileList"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="4"
                         SelectionChanged="ProfileList_SelectionChanged" />
            </Grid>
        </Border>

        <Button Grid.Row="3"
                x:Name="NewProfileButton"
                Content="＋ 新组合"
                HorizontalAlignment="Left"
                Margin="0,12,0,0"
                MinHeight="36"
                Padding="16,6"
                BorderThickness="0"
                Cursor="Hand"
                FontWeight="SemiBold"
                Background="#FF3C332C"
                Foreground="#FFFFF7E8"
                Click="NewProfile_Click" />

        <StackPanel Grid.Row="4"
                    x:Name="NewNamePanel"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
            <TextBlock Text="新组合名称"
                       Foreground="#FF6F6258"
                       Margin="0,0,0,6" />
            <TextBox x:Name="NewNameBox"
                     MinHeight="36"
                     VerticalContentAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="取消"
                    IsCancel="True"
                    MinWidth="96"
                    MinHeight="38"
                    Padding="14,8"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    Margin="0,0,12,0"
                    Background="#FFE7D9C8"
                    Foreground="#FF201913"
                    Click="Cancel_Click" />
            <Button Content="保存"
                    IsDefault="True"
                    MinWidth="96"
                    MinHeight="38"
                    Padding="14,8"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    Background="#FFC96A32"
                    Foreground="#FFFFFFFF"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
