<Window x:Class="StS2ModManager.StartupConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="启动配置"
        Width="680"
        Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F0E5"
        FontFamily="Bahnschrift">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="选择游戏目录"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#FF201913" />

        <TextBlock Grid.Row="1"
                   Margin="0,12,0,0"
                   Foreground="#FF6F6258"
                   TextWrapping="Wrap"
                   Text="首次没有可用的 Steam 启动记录时，请手动选择 Slay the Spire 2 游戏目录，或使用自动扫描。"/>

        <Grid Grid.Row="2"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="GamePathBox"
                     MinHeight="38"
                     VerticalContentAlignment="Center" />

            <Button Grid.Column="1"
                    Margin="12,0,0,0"
                    MinWidth="100"
                    Background="#FFE7D9C8"
                    Foreground="#FF201913"
                    Content="浏览..."
                    Click="Browse_Click" />
        </Grid>

        <Grid Grid.Row="3"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    MinWidth="120"
                    Background="#FF3C332C"
                    Foreground="#FFFFF7E8"
                    Content="自动扫描"
                    Click="AutoScan_Click" />

            <TextBlock x:Name="StatusText"
                       Grid.Column="1"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="#FF6F6258"
                       TextWrapping="Wrap" />
        </Grid>

        <Border Grid.Row="4"
                Margin="0,18,0,18"
                Padding="12"
                CornerRadius="14"
                Background="#FFFFFFFF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="自动扫描结果"
                           FontWeight="SemiBold"
                           Foreground="#FF201913" />

                <ListBox x:Name="CandidateList"
                         Grid.Row="1"
                         Margin="0,10,0,0"
                         SelectionChanged="CandidateList_SelectionChanged" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="取消"
                    MinWidth="88"
                    MinHeight="38"
                    Margin="0,0,12,0"
                    Background="#FFE7D9C8"
                    Foreground="#FF201913"
                    Click="Cancel_Click" />
            <Button Content="确认"
                    MinWidth="88"
                    MinHeight="38"
                    Background="#FFC96A32"
                    Foreground="#FFFFFFFF"
                    Click="Confirm_Click" />
        </StackPanel>
    </Grid>
</Window>
