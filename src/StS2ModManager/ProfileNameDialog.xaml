<Window x:Class="StS2ModManager.ProfileNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保存配置组合"
        Width="420"
        Height="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFF8F0E5"
        FontFamily="Bahnschrift">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="配置组合名称"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#FF201913" />
        <TextBox x:Name="ProfileNameBox"
                 Grid.Row="1"
                 MinHeight="36"
                 VerticalAlignment="Center" />
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="取消"
                    MinWidth="88"
                    MinHeight="38"
                    Margin="0,0,12,0"
                    Click="Cancel_Click" />
            <Button Content="保存"
                    MinWidth="88"
                    MinHeight="38"
                    Background="#FFC96A32"
                    Foreground="#FFFFFFFF"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
