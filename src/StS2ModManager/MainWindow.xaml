<Window x:Class="StS2ModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="StS2 Mod Manager"
        Icon="Resources/AppIcon.ico"
        MinHeight="560"
        MinWidth="860"
        Height="620"
        Width="980"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F0E5"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="TextButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                CornerRadius="22"
                Background="#FF2A211B">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Slay the Spire 2 MOD Manager"
                           Foreground="#FFFFF7E8"
                           FontSize="30"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
                <Border Grid.Column="1"
                        Padding="18,10"
                        CornerRadius="16"
                        VerticalAlignment="Center"
                        Background="#33FFFFFF">
                    <TextBlock Text="{Binding ModCountText}"
                               Foreground="#FFFFF7E8"
                               FontSize="18"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18"
                Padding="8"
                CornerRadius="18"
                Background="#FFFFFFFF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="14,12,14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="配置组合"
                               VerticalAlignment="Center"
                               Foreground="#FF6F6258"
                               FontWeight="SemiBold" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding ProfileNames}"
                              SelectedItem="{Binding SelectedProfileName, Mode=TwoWay}"
                              Margin="12,0,0,0"
                              MinHeight="36" />
                    <Button Grid.Column="2"
                            Content="应用"
                            Margin="12,0,0,0"
                            MinHeight="36"
                            Background="#FFE7D9C8"
                            Foreground="#FF201913"
                            Click="ApplyProfile_Click" />
                    <Button Grid.Column="3"
                            Content="保存当前为组合"
                            Margin="12,0,0,0"
                            MinHeight="36"
                            Background="#FF3C332C"
                            Foreground="#FFFFF7E8"
                            Click="SaveProfile_Click" />
                    <Button Grid.Column="4"
                            Content="删除"
                            Margin="12,0,0,0"
                            MinHeight="36"
                            Background="#FFE7D9C8"
                            Foreground="#FF201913"
                            Click="DeleteProfile_Click" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{Binding StatusText}"
                           Visibility="{Binding StatusVisibility}"
                           Margin="14,0,14,8"
                           Foreground="#FFB9472B" />

                <ListView Grid.Row="2"
                          ItemsSource="{Binding Mods}"
                          BorderThickness="0"
                          Background="Transparent"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border HorizontalAlignment="Stretch"
                                    Padding="14,14,20,14"
                                    CornerRadius="14"
                                    Background="#FFF8F0E5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="88" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center"
                                              Click="ModToggle_Click" />

                                    <Button Grid.Column="2"
                                            Style="{StaticResource TextButton}"
                                            Click="ModDetails_Click">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF201913"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Note}"
                                                       Visibility="{Binding NoteVisibility}"
                                                       Margin="0,4,0,0"
                                                       Foreground="#FF6F6258"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding StateText}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding StateBrush}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="关闭"
                    Background="#FFE7D9C8"
                    Foreground="#FF201913"
                    Click="Cancel_Click" />
            <Button Grid.Column="1"
                    Content="启动游戏"
                    Margin="12,0,0,0"
                    Background="#FFC96A32"
                    Foreground="#FFFFF7E8"
                    Click="SaveAndLaunch_Click" />
        </Grid>
    </Grid>
</Window>
