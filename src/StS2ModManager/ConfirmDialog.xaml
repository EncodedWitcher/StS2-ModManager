<Window x:Class="StS2ModManager.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#FFF8F0E5"
        FontFamily="Bahnschrift">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#FF201913" />

        <TextBlock x:Name="MessageText"
                   Grid.Row="1"
                   Margin="0,14,0,22"
                   FontSize="14"
                   Foreground="#FF3C332C"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="NegativeButton"
                    Content="取消"
                    IsCancel="True"
                    MinWidth="96"
                    MinHeight="38"
                    Padding="14,8"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    Margin="0,0,12,0"
                    Background="#FFE7D9C8"
                    Foreground="#FF201913"
                    Click="Negative_Click" />
            <Button x:Name="PositiveButton"
                    Content="确定"
                    IsDefault="True"
                    MinWidth="96"
                    MinHeight="38"
                    Padding="14,8"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"
                    Background="#FFC96A32"
                    Foreground="#FFFFFFFF"
                    Click="Positive_Click" />
        </StackPanel>
    </Grid>
</Window>
